{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wxynora/together-watch/schema/watch-v1.schema.json",
  "title": "TogetherWatch Protocol v1",
  "type": "object",
  "$defs": {
    "playbackSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_id",
        "playhead_ms",
        "duration_ms",
        "is_playing",
        "playback_rate",
        "timeline_epoch",
        "snapshot_seq",
        "captured_at"
      ],
      "properties": {
        "media_id": { "type": "string", "minLength": 1 },
        "playhead_ms": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 1 },
        "is_playing": { "type": "boolean" },
        "playback_rate": { "type": "number", "minimum": 0.25, "maximum": 4.0 },
        "timeline_epoch": { "type": "integer", "minimum": 0 },
        "snapshot_seq": { "type": "integer", "minimum": 1 },
        "captured_at": { "type": "string", "minLength": 1 }
      }
    },
    "clientCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["playback_snapshot"],
      "properties": {
        "playback_snapshot": { "type": "boolean" },
        "local_media": { "type": "boolean", "default": false },
        "client_sampling": { "type": "boolean", "default": false },
        "danmaku_overlay": { "type": "boolean", "default": false },
        "risk_overlay": { "type": "boolean", "default": false },
        "visual_context": { "type": "boolean", "default": false }
      }
    },
    "localMediaCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_play",
        "can_seek",
        "can_read_future",
        "can_export_frames",
        "can_export_audio",
        "has_audio",
        "is_drm"
      ],
      "properties": {
        "can_play": { "type": "boolean" },
        "can_seek": { "type": "boolean" },
        "can_read_future": { "type": "boolean" },
        "can_export_frames": { "type": "boolean" },
        "can_export_audio": { "type": "boolean" },
        "has_audio": { "type": "boolean" },
        "is_drm": { "type": "boolean" }
      }
    },
    "localMedia": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_asset_id",
        "media_revision",
        "capabilities",
        "selected_audio",
        "selected_subtitle"
      ],
      "properties": {
        "local_asset_id": { "type": "string", "minLength": 1 },
        "media_revision": { "type": "string", "minLength": 1 },
        "capabilities": { "$ref": "#/$defs/localMediaCapabilities" },
        "selected_audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["track_id", "language", "label"],
          "properties": {
            "track_id": { "type": "string" },
            "language": { "type": "string" },
            "label": { "type": "string" }
          }
        },
        "selected_subtitle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "track_id", "language", "label", "format", "offset_ms"],
          "properties": {
            "kind": { "enum": ["none", "embedded", "external"] },
            "track_id": { "type": "string" },
            "language": { "type": "string" },
            "label": { "type": "string" },
            "format": { "enum": ["", "srt", "vtt"] },
            "offset_ms": { "type": "integer" }
          }
        }
      }
    },
    "clientLease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client_seen_at", "expires_at", "valid"],
      "properties": {
        "client_seen_at": { "type": "string" },
        "expires_at": { "type": "string" },
        "valid": { "type": "boolean" }
      }
    },
    "analysisCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "amount_usd",
        "complete",
        "pricing_complete",
        "provider_calls",
        "priced_calls",
        "unpriced_calls",
        "pending_jobs",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "currency": { "const": "USD" },
        "amount_usd": { "type": "number", "minimum": 0 },
        "complete": { "type": "boolean" },
        "pricing_complete": { "type": "boolean" },
        "provider_calls": { "type": "integer", "minimum": 0 },
        "priced_calls": { "type": "integer", "minimum": 0 },
        "unpriced_calls": { "type": "integer", "minimum": 0 },
        "pending_jobs": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "breakdown": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "clientSamplePlan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "plan_id",
        "media_id",
        "media_revision",
        "timeline_epoch",
        "purpose",
        "managed_by",
        "target_timestamps_ms",
        "allowed_start_ms",
        "allowed_end_ms",
        "expires_at"
      ],
      "properties": {
        "plan_id": { "type": "string", "minLength": 1 },
        "media_id": { "type": "string", "minLength": 1 },
        "media_revision": { "type": "string", "minLength": 1 },
        "timeline_epoch": { "type": "integer", "minimum": 0 },
        "purpose": { "enum": ["identify", "timeline_prepass", "rolling"] },
        "managed_by": { "const": "client" },
        "target_timestamps_ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "allowed_start_ms": { "type": "integer", "minimum": 0 },
        "allowed_end_ms": { "type": "integer", "minimum": 0 },
        "audio_required": { "type": "boolean" },
        "accepted_image_mime_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accepted_audio_mime_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expires_at": { "type": "string", "minLength": 1 }
      }
    },
    "viewingPart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part_key",
        "media_id",
        "part_index",
        "part_title",
        "played_duration_ms",
        "completed_at",
        "completion_event_id",
        "last_session_id"
      ],
      "properties": {
        "part_key": { "type": "string", "minLength": 1 },
        "media_id": { "type": "string", "minLength": 1 },
        "part_index": { "type": "integer", "minimum": 1 },
        "part_title": { "type": "string" },
        "played_duration_ms": { "type": "integer", "minimum": 0 },
        "completed_at": { "type": "string" },
        "completion_event_id": { "type": "string" },
        "last_session_id": { "type": "string" }
      }
    },
    "viewingFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame_id", "media_id", "at_ms", "image_url", "selected_at"],
      "properties": {
        "frame_id": { "type": "string", "minLength": 1 },
        "media_id": { "type": "string", "minLength": 1 },
        "at_ms": { "type": "integer", "minimum": 0 },
        "image_url": { "type": "string", "minLength": 1 },
        "selected_at": { "type": "string", "minLength": 1 }
      }
    },
    "viewingFrameCapture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "viewing_id",
        "session_id",
        "media_id",
        "timeline_epoch",
        "at_ms",
        "width",
        "height",
        "mime_type",
        "image_url",
        "created_at"
      ],
      "properties": {
        "frame_id": { "type": "string", "minLength": 1 },
        "viewing_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "media_id": { "type": "string", "minLength": 1 },
        "timeline_epoch": { "type": "integer", "minimum": 0 },
        "at_ms": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "mime_type": { "const": "image/jpeg" },
        "image_url": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "minLength": 1 }
      }
    },
    "viewingTicket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ticket_id",
        "viewing_id",
        "work_key",
        "title",
        "cover_url",
        "companion",
        "created_at",
        "completed_at",
        "played_duration_ms",
        "part_count",
        "completed_parts",
        "last_session_id",
        "back_frame"
      ],
      "properties": {
        "ticket_id": { "type": "string", "minLength": 1 },
        "viewing_id": { "type": "string", "minLength": 1 },
        "work_key": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "cover_url": { "type": "string" },
        "companion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "created_at": { "type": "string", "minLength": 1 },
        "completed_at": { "type": "string", "minLength": 1 },
        "played_duration_ms": { "type": "integer", "minimum": 0 },
        "part_count": { "type": "integer", "minimum": 1 },
        "completed_parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/viewingPart" }
        },
        "last_session_id": { "type": "string" },
        "back_frame": {
          "oneOf": [
            { "$ref": "#/$defs/viewingFrame" },
            { "type": "null" }
          ]
        }
      }
    },
    "viewingProgress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "viewing_id",
        "work_key",
        "title",
        "cover_url",
        "source",
        "source_reference",
        "media_id",
        "part_key",
        "part_index",
        "part_count",
        "part_title",
        "playhead_ms",
        "duration_ms",
        "played_duration_ms",
        "saved_at",
        "analysis_covered_until_ms",
        "analysis_retained",
        "ticket_back_frame"
      ],
      "properties": {
        "viewing_id": { "type": "string", "minLength": 1 },
        "work_key": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "cover_url": { "type": "string" },
        "source": { "type": "string", "minLength": 1 },
        "source_reference": { "type": "string" },
        "media_id": { "type": "string", "minLength": 1 },
        "part_key": { "type": "string", "minLength": 1 },
        "part_index": { "type": "integer", "minimum": 1 },
        "part_count": { "type": "integer", "minimum": 1 },
        "part_title": { "type": "string" },
        "playhead_ms": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "integer", "minimum": 1 },
        "played_duration_ms": { "type": "integer", "minimum": 0 },
        "saved_at": { "type": "string", "minLength": 1 },
        "analysis_covered_until_ms": { "type": "integer", "minimum": 0 },
        "analysis_retained": { "const": true },
        "ticket_back_frame": {
          "oneOf": [
            { "$ref": "#/$defs/viewingFrame" },
            { "type": "null" }
          ]
        }
      }
    },
    "viewingSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "viewing_id",
        "work_key",
        "title",
        "cover_url",
        "companion",
        "part_count",
        "parts",
        "played_duration_ms",
        "completed",
        "completed_at",
        "ticket",
        "created_at",
        "updated_at",
        "progress",
        "completed_analysis_cache_expires_at"
      ],
      "properties": {
        "viewing_id": { "type": "string", "minLength": 1 },
        "work_key": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "cover_url": { "type": "string" },
        "companion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "part_count": { "type": "integer", "minimum": 1 },
        "parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/viewingPart" }
        },
        "played_duration_ms": { "type": "integer", "minimum": 0 },
        "completed": { "type": "boolean" },
        "completed_at": { "type": "string" },
        "ticket": {
          "oneOf": [
            { "$ref": "#/$defs/viewingTicket" },
            { "type": "null" }
          ]
        },
        "created_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "progress": {
          "oneOf": [
            { "$ref": "#/$defs/viewingProgress" },
            { "type": "null" }
          ]
        },
        "completed_analysis_cache_expires_at": { "type": "string" }
      }
    },
    "danmakuToolInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_ms", "text"],
      "properties": {
        "target_ms": { "type": "integer", "minimum": 0 },
        "text": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    }
  }
}
