{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lean In analysis result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "familiarity",
    "canonical_identity",
    "timeline_sections",
    "plot_chunks",
    "story_so_far",
    "story_state",
    "risk_events",
    "analysis_notes"
  ],
  "properties": {
    "familiarity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "identity", "confidence"],
      "properties": {
        "status": { "enum": ["recognized", "partial", "unknown"] },
        "identity": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "canonical_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "original_title", "year"],
      "properties": {
        "title": { "type": "string" },
        "original_title": { "type": "string" },
        "year": { "type": "integer", "minimum": 0 }
      }
    },
    "timeline_sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "start_ms", "end_ms", "confidence"],
        "properties": {
          "kind": {
            "enum": [
              "recap",
              "cold_open",
              "intro",
              "content",
              "credits_over_story",
              "outro",
              "preview",
              "post_credit",
              "non_story",
              "unknown"
            ]
          },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "plot_chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "start_ms",
          "end_ms",
          "description",
          "characters",
          "tags",
          "confidence"
        ],
        "properties": {
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" },
          "characters": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "story_so_far": {
      "type": "object",
      "additionalProperties": false,
      "required": ["through_ms", "summary", "background", "characters", "unresolved"],
      "properties": {
        "through_ms": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string" },
        "background": { "type": "string" },
        "characters": { "type": "array", "items": { "type": "string" } },
        "unresolved": { "type": "array", "items": { "type": "string" } }
      }
    },
    "story_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["characters", "locations", "events", "unresolved"],
      "properties": {
        "characters": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "events": { "type": "array", "items": { "type": "string" } },
        "unresolved": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_type",
          "severity",
          "start_ms",
          "end_ms",
          "label",
          "companion_hint",
          "confidence"
        ],
        "properties": {
          "risk_type": {
            "enum": ["jumpscare", "loud_noise", "violence", "gore", "unsettling", "other"]
          },
          "severity": { "type": "integer", "minimum": 1, "maximum": 3 },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "companion_hint": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "analysis_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
